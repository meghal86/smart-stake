{
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/legacy/:path*",
      "destination": "https://your-legacy-app-url.vercel.app/legacy/:path*"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "LEGACY_PROXY_BASE": "https://your-legacy-app-url.vercel.app"
  }
}