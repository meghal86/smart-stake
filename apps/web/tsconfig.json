{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@sdk/*": [
        "../../packages/sdk/src/*"
      ],
      "@ui/*": [
        "../../packages/ui/src/*"
      ],
      "@types/*": [
        "../../packages/types/src/*"
      ],
      "@config/*": [
        "../../packages/config/*"
      ]
    },
    "incremental": true,
    "jsx": "preserve",
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../../src",
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}
